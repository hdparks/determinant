{
  "name": "@determinant/server",
  "version": "1.0.0",
  "description": "Determinant API server",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:web": "cd ../../ && npm run build -w packages/web",
    "build:full": "npm run build:web && npm run build && npm run copy:web",
    "copy:web": "rimraf public && cpy '../web/dist/**/*' public --parents",
    "dev": "NODE_ENV=development tsx watch --ignore '../web/node_modules/**' --ignore '../web/dist/**' src/index.ts",
    "start": "NODE_ENV=production node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "determinant",
    "server"
  ],
  "license": "MIT",
  "dependencies": {
    "@determinant/types": "file:../types",
    "better-sqlite3": "^11.7.0",
    "express": "^5.0.1",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.1",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cors": "^2.8.6",
    "cpy-cli": "^7.0.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}

{
  "name": "@determinant/client",
  "version": "1.0.0",
  "description": "Determinant CLI client",
  "type": "module",
  "bin": {
    "det": "./dist/cli.js",
    "boblin": "./dist/run.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "cli": "tsx src/cli.ts",
    "run": "tsx src/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "determinant",
    "client",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@determinant/types": "file:../types",
    "play-sound": "^1.1.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/play-sound": "^1.1.0",
    "@vitest/ui": "^4.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}

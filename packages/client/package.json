{
  "name": "@determinant/client",
  "version": "1.0.0",
  "description": "Determinant CLI client",
  "type": "module",
  "bin": {
    "det": "./dist/cli.js",
    "boblin": "./dist/run.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "cli": "tsx src/cli.ts",
    "run": "tsx src/run.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "keywords": ["determinant", "client", "cli"],
  "license": "MIT",
  "dependencies": {
    "@determinant/types": "file:../types",
    "play-sound": "^1.1.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^22.13.1",
    "@types/play-sound": "^1.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
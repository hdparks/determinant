# Determinant Server Configuration
DETERMINANT_SERVER_URL=http://localhost:10110
DETERMINANT_API_KEY=your-api-key-here

# Notification Settings
DETERMINANT_NOTIFY_ENABLED=true
DETERMINANT_NOTIFY_SOUND_ENABLED=true
DETERMINANT_NOTIFY_VOLUME=0.5
DETERMINANT_NOTIFY_VERBOSE=false

# Custom Sound Paths (optional)
# DETERMINANT_NOTIFY_SOUND_SUCCESS=/path/to/success.wav
# DETERMINANT_NOTIFY_SOUND_ERROR=/path/to/error.wav
# DETERMINANT_NOTIFY_SOUND_WARNING=/path/to/warning.wav

{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "*": "allow",
      "*.db": "deny",
      "*.db-shm": "deny",
      "*.db-wal": "deny",
      "*.db-journal": "deny",
      "*.sqlite": "deny",
      "*.sqlite3": "deny",
    },
    "bash": {
      "*": "allow",
      "rm *.db*": "deny",
      "mv *.db*": "deny",
    }
  }
}
